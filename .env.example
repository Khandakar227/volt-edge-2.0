# Copy to .env and fill in real values. .env is gitignored.
NGROK_AUTH_TOKEN=
NGROK_DOMAIN=elective-reoccupy-unknown.ngrok-free.dev

# Local ports used by scripts/start-ngrok.sh.
PUBLIC_PORT=8080
BACKEND_PORT=8787

# Usually false. Set true only if you intentionally run multiple ngrok agents
# behind the same endpoint.
NGROK_POOLING_ENABLED=false
